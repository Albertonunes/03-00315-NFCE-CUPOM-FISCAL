  object QryCstCliente: TFDQuery
    Connection = DmdPrincipal.FDConexao
    SQL.Strings = (
      
        'SELECT A.NOME,A.COD_CLIENTE,A.CPF_CNPJ,A.ENDERECO,A.ENDERECO_NUM' +
        ',A.ENDERECO_COMPL,'
      
        'A.BAIRRO,A.CIDADE,A.UF,A.TEL1, B.VENDEDOR_APELIDO,A.CONTATO1,A.C' +
        'EP,A.EMAIL,A.TIPO,'
      
        'A.ENDERECO_COB,A.ENDERECO_COB_NUM,A.ENDERECO_COB_COMPL,A.CEP_COB' +
        ',A.BAIRRO_COB,'
      
        'A.CIDADE_COB,A.UF_COB,A.ENDERECO_ENT,A.ENDERECO_ENT_NUM,A.ENDERE' +
        'CO_ENT_COMPL,'
      
        'A.CEP_ENT,A.BAIRRO_ENT,A.CIDADE_ENT,A.UF_ENT,A.PRACA,A.FANTASIA,' +
        'A.COD_INTERNO'
      'FROM GESTOR_CLIENTE A'
      'LEFT JOIN VENDEDOR B ON A.VENDEDOR = B.VENDEDOR_ID')
    Left = 124
    Top = 131
