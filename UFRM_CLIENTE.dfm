  object QryLimiteUsado: TFDQuery
    Connection = DmdPrincipal.FDConexao
    SQL.Strings = (
      
        'SELECT SUM((I.QUANT - I.QTDE_FAT) *  I.VLR_UNIT)+(ISNULL((SELECT' +
        ' SUM(SaldoDocumento) '
      '            FROM GESTOR_CTARECEBER'
      
        '           WHERE ((Posicao = '#39'ABERTA'#39') OR (Posicao = '#39'BX.PARCIAL' +
        #39'))'
      
        '           AND (DtVencimento < :vencto) AND COD_CLIENTE = :CLI),' +
        '0))  AS SALDO'
      'FROM         PEDIDO_MATERIAIS_ITENS_CLIENTE AS I LEFT OUTER JOIN'
      '             PEDIDO_MATERIAIS_CLIENTE AS P ON I.PEDID = P.PEDID'
      'WHERE     ((P.POSICAO = '#39'APROVADO'#39' OR P.POSICAO = '#39'FECHADO'#39'))'
      '    AND (P.STATUS = '#39'PEDIDO'#39') AND ((I.QUANT - I.QTDE_FAT) > 0)'
      '    AND P.COD_CLIENTE = :CLI'
      'GROUP BY P.COD_CLIENTE    '
      '')
    Left = 533
    Top = 153
    ParamData = <
      item
        Name = 'vencto'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Name = 'CLI'
        DataType = ftInteger
        ParamType = ptInput
      end>
    object QryLimiteUsadoSALDO: TFloatField
      FieldName = 'SALDO'
    end
  end
