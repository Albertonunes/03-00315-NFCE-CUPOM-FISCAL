  object QryNotafiscal: TFDQuery
    MasterSource = DSCLIENTE
    MasterFields = 'COD_CLIENTE'
    Connection = DmdPrincipal.FDConexao
    SQL.Strings = (
      
        'SELECT A.NF_NUMERO, A.NF_DT_EMISSAO, A.GESTOR_CLIENTE, A.NOME, A' +
        '.NF_VLR_TOTAL, A.NF_VLR_TOTMERC,'
      
        'A.NF_VLR_ICMS, A.NF_VLR_ISS, A.NF_VLR_IPI, A.STATUS, A.SERIE_ID,' +
        ' A.IDORIG, A.NF_ID,PEDIDO_ID,B.FANTASIA,'
      
        'A.TRANSPORTADORA,A.NF_VOL_PESOBRUTO,A.FPAGTO,A.CFOP_ID,A.NF_DT_E' +
        'NT_SAI,A.DIAG_EMPRESA'
      
        'FROM NOTA_FISCAL A LEFT JOIN EMPRESA B ON A.DIAG_EMPRESA=B.DIAG_' +
        'EMPRESA'
      'WHERE (A.GESTOR_CLIENTE=:COD_CLIENTE) '
      'ORDER BY B.DIAG_EMPRESA,A.NF_DT_EMISSAO DESC')
