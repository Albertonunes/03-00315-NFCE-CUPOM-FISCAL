  object QryMateriais: TFDQuery
    Connection = DmdPrincipal.FDConexao
    SQL.Strings = (
      'SELECT     A.CODID, A.COD_INTERNO, A.DESCRICAO, A.DESC_REDUZIDA'
      'FROM         MATERIAIS AS A LEFT OUTER JOIN'
      
        '                      MATERIAIS_TIPO AS B ON A.TIPO_MATERIAL = B' +
        '.TIPO'
      'WHERE     (A.BLOQUEIO = '#39'N'#39') AND (B.FLAGVENDA = '#39'S'#39')'
      'ORDER BY A.DESCRICAO')
    Left = 595
    Top = 192
    object QryMateriaisCODID: TFDAutoIncField
      FieldName = 'CODID'
      ReadOnly = True
    end
