  object QryCstPed: TFDQuery
    MasterSource = DSCLIENTE
    MasterFields = 'COD_CLIENTE'
    Connection = DmdPrincipal.FDConexao
    SQL.Strings = (
      
        'SELECT A.PEDIDO, A.DATA, A.COD_CLIENTE, A.POSICAO, A.FPGTO, A.PR' +
        'AZO_ENTREGA,'
      'B.NOME, A.VENDEDOR, A.FILIAL,C.FANTASIA,A.PEDID'
      'FROM PEDIDO_MATERIAIS_CLIENTE A LEFT JOIN '
      'GESTOR_CLIENTE B ON A.COD_CLIENTE = B.COD_CLIENTE LEFT JOIN'
      'EMPRESA C ON A.FILIAL=1'
      'WHERE (A.POSICAO <> '#39'.X'#39') AND (A.COD_CLIENTE=:COD_CLIENTE)'
      'ORDER BY A.DATA DESC')
